<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Préparer ma croisière — Filovent</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:       #081C37;
    --cta:        #AF141C;
    --cta-dark:   #8B1015;
    --blue-1:     #015AA5;
    --blue-5:     #1793D7;
    --gray-bg:    #F4F2EC;
    --gray-0:     #F5F2ED;
    --gray-1:     #DDDAD3;
    --gray-2:     #E8E6DF;
    --gray-6:     #E0E4E4;
    --gray-7:     #CCCCCC;
    --gray-8:     #666666;
    --gray-9:     #B1B5AF;
    --white:      #FFFFFF;
    --font:       'Montserrat', Arial, sans-serif;
    --font-serif: 'Lora', Georgia, serif;
  }

  body {
    font-family: var(--font);
    background: var(--gray-bg);
    color: var(--navy);
    font-size: 16px;
    line-height: 1.6;
  }

  /* ── HEADER ── */
  .header {
    background: var(--white);
    border-bottom: 1px solid var(--gray-6);
    padding: 0 32px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
  }
  .header-logo {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.5px;
    text-decoration: none;
  }
  .header-advisor {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--navy);
  }
  .header-advisor img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--gray-1);
  }
  .header-advisor-name { font-weight: 600; }
  .header-advisor-phone {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--navy);
    color: var(--white);
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: var(--navy);
  }

  /* ── LAYOUT ── */
  .layout {
    display: flex;
    min-height: calc(100vh - 60px);
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: var(--white);
    border-right: 1px solid var(--gray-6);
    padding: 32px 0;
  }
  .sidebar-nav { list-style: none; }
  .sidebar-nav li { border-bottom: 1px solid var(--gray-6); }
  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 13px 20px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--navy);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .sidebar-nav a:hover { background: var(--gray-0); }
  .sidebar-nav a.active {
    background: var(--gray-bg);
    color: var(--cta);
    font-weight: 700;
    border-left: 3px solid var(--cta);
  }
  .sidebar-nav .arrow {
    font-size: 10px;
    color: var(--gray-9);
    margin-right: 2px;
  }
  .sidebar-section-sep {
    height: 1px;
    background: var(--gray-1);
    margin: 12px 0;
  }

  /* ── MAIN CONTENT ── */
  .main {
    flex: 1;
    padding: 40px 48px 60px;
    max-width: 860px;
  }

  /* ── BREADCRUMB ── */
  .breadcrumb {
    font-size: 12px;
    color: var(--gray-8);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .breadcrumb a { color: var(--blue-1); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb-sep { color: var(--gray-7); }

  /* ── PAGE TITLE ── */
  .page-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 6px;
    line-height: 1.2;
  }
  .page-subtitle {
    font-size: 15px;
    color: var(--gray-8);
    margin-bottom: 32px;
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ── INTRO BOX ── */
  .intro-box {
    background: var(--white);
    border: 1px solid var(--gray-6);
    border-left: 4px solid var(--blue-5);
    border-radius: 4px;
    padding: 20px 24px;
    margin-bottom: 32px;
    font-size: 14.5px;
    color: var(--navy);
    line-height: 1.7;
  }
  .intro-box p + p { margin-top: 8px; }
  .intro-benefits {
    list-style: none;
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .intro-benefits li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }
  .intro-benefits li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cta);
    flex-shrink: 0;
  }

  /* ── SECTION ── */
  .section {
    background: var(--white);
    border: 1px solid var(--gray-6);
    border-radius: 4px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 24px;
    background: var(--navy);
    cursor: pointer;
    user-select: none;
  }
  .section-number {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--cta);
    color: var(--white);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .section-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.2px;
    flex: 1;
  }
  .section-toggle {
    color: var(--white);
    font-size: 12px;
    opacity: 0.7;
    transition: transform 0.2s;
  }
  .section-toggle.open { transform: rotate(180deg); }
  .section-body {
    padding: 24px 28px;
    display: none;
    border-top: 1px solid var(--gray-6);
  }
  .section-body.open { display: block; }

  /* ── SUBSECTION ── */
  .subsection { margin-bottom: 24px; }
  .subsection:last-child { margin-bottom: 0; }
  .subsection-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--navy);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--gray-1);
  }

  /* ── ALERT BOXES ── */
  .alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 4px;
    font-size: 13.5px;
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .alert-warning {
    background: #FFF8E6;
    border: 1px solid #F5C842;
    color: #7A5800;
  }
  .alert-info {
    background: #EDF4FB;
    border: 1px solid #A8CEEA;
    color: #0C3A6B;
  }
  .alert-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }

  /* ── INFO ROWS ── */
  .info-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid var(--gray-0);
    font-size: 14px;
    line-height: 1.5;
  }
  .info-row:last-child { border-bottom: none; }
  .info-row-label {
    font-weight: 600;
    color: var(--navy);
    min-width: 160px;
    flex-shrink: 0;
  }
  .info-row-value { color: var(--gray-8); }

  /* ── BULLET LIST ── */
  .bullet-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 10px 0;
  }
  .bullet-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--navy);
  }
  .bullet-list li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cta);
    flex-shrink: 0;
    margin-top: 7px;
  }
  .bullet-list.sub {
    margin-left: 20px;
    margin-top: 4px;
  }
  .bullet-list.sub li::before { background: var(--gray-7); }

  /* ── BLOCK ROW (bold label + text) ── */
  .block-row {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-0);
    font-size: 14px;
    line-height: 1.6;
  }
  .block-row:last-child { border-bottom: none; }
  .block-row-label {
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 2px;
  }
  .block-row-text { color: var(--gray-8); }

  /* ── EMAIL CTA ── */
  .email-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--navy);
    color: var(--white);
    padding: 10px 18px;
    border-radius: 4px;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    margin: 16px 0 8px;
    transition: background 0.15s;
  }
  .email-cta:hover { background: var(--blue-1); }

  /* ── CHECKLIST ── */
  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .checklist li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 4px;
    border-bottom: 1px solid var(--gray-0);
    font-size: 14px;
    cursor: pointer;
    transition: background 0.1s;
    border-radius: 2px;
  }
  .checklist li:last-child { border-bottom: none; }
  .checklist li:hover { background: var(--gray-bg); }
  .checklist-box {
    width: 18px;
    height: 18px;
    border: 2px solid var(--gray-7);
    border-radius: 3px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .checklist li.checked .checklist-box {
    background: var(--cta);
    border-color: var(--cta);
  }
  .checklist li.checked .checklist-box::after {
    content: '✓';
    color: white;
    font-size: 11px;
    font-weight: 700;
  }
  .checklist li.checked .checklist-label {
    text-decoration: line-through;
    color: var(--gray-9);
  }
  .checklist-label { flex: 1; color: var(--navy); }

  /* ── PROGRESS BAR ── */
  .progress-wrap {
    background: var(--gray-bg);
    border: 1px solid var(--gray-6);
    border-radius: 4px;
    padding: 16px 20px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .progress-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    white-space: nowrap;
  }
  .progress-bar-bg {
    flex: 1;
    height: 8px;
    background: var(--gray-1);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: var(--cta);
    border-radius: 99px;
    transition: width 0.4s ease;
    width: 0%;
  }
  .progress-count {
    font-size: 13px;
    font-weight: 700;
    color: var(--cta);
    white-space: nowrap;
  }

  /* ── HELP BOX ── */
  .help-box {
    background: var(--navy);
    border-radius: 4px;
    padding: 20px 24px;
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .help-box-icon { font-size: 24px; }
  .help-box-text { flex: 1; }
  .help-box-title { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
  .help-box-sub { font-size: 13px; color: rgba(255,255,255,0.7); }
  .help-box-link {
    color: var(--white);
    font-weight: 600;
    font-size: 13.5px;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── SEPARATOR ── */
  .sep { height: 1px; background: var(--gray-1); margin: 20px 0; }

  /* ── TAG ── */
  .tag {
    display: inline-block;
    background: var(--gray-bg);
    color: var(--navy);
    border: 1px solid var(--gray-1);
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 600;
  }

</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <a href="#" class="header-logo">Filovent</a>
  <div class="header-advisor">
    <div style="width:36px;height:36px;border-radius:50%;background:var(--gray-1);display:flex;align-items:center;justify-content:center;font-size:18px;">👤</div>
    <div>
      <div class="header-advisor-name">Votre conseiller Filovent</div>
      <div style="font-size:12px;color:var(--gray-8);">info@filovent.com</div>
    </div>
    <a href="tel:+33170809752" class="header-advisor-phone">📞 +33 1 70 80 97 52</a>
  </div>
  <div class="header-right">
    <span>🇫🇷 fr</span>
    <span style="font-weight:600;">Bonjour</span>
  </div>
</header>

<!-- LAYOUT -->
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <ul class="sidebar-nav">
      <li><a href="#"><span class="arrow">›</span> Mes réservations</a></li>
      <li><a href="#"><span class="arrow">›</span> Mes devis</a></li>
      <li><a href="#"><span class="arrow">›</span> Partagés avec moi</a></li>
      <li><a href="#"><span class="arrow">›</span> Mes bons d'achats</a></li>
    </ul>
    <div class="sidebar-section-sep"></div>
    <ul class="sidebar-nav">
      <li>
        <a href="#" style="font-size:12px;color:var(--gray-8);padding:8px 20px;">Mon tableau de bord</a>
      </li>
      <li><a href="#">Bulletin de réservation</a></li>
      <li><a href="#">Mes croisières</a></li>
      <li><a href="#" class="active">Préparer ma croisière</a></li>
      <li><a href="#">Assurance</a></li>
      <li><a href="#">Évaluer ma croisière</a></li>
      <li><a href="#">Coordonnées partenaire</a></li>
    </ul>
    <div class="sidebar-section-sep"></div>
    <ul class="sidebar-nav">
      <li><a href="#"><span class="arrow">›</span> Mon profil</a></li>
      <li><a href="#"><span class="arrow">›</span> Mon CV nautique</a></li>
    </ul>
    <div class="sidebar-section-sep"></div>
    <ul class="sidebar-nav">
      <li><a href="#" style="color:var(--gray-8);">Déconnexion</a></li>
    </ul>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb">
      <a href="#">Espace client</a>
      <span class="breadcrumb-sep">›</span>
      <span>Préparer ma croisière</span>
    </nav>

    <!-- TITLE -->
    <h1 class="page-title">Préparer ma croisière</h1>
    <p class="page-subtitle">Toutes les informations essentielles avant votre départ, quelle que soit la destination.</p>

    <!-- INTRO -->
    <div class="intro-box">
      <p>Nous avons conçu cette page pour vous aider à préparer votre voyage simplement. Certaines rubriques peuvent ne pas vous concerner — c'est le cas si vos vols sont inclus, ou si votre destination ne nécessite pas de visa. Passez simplement à la suite.</p>
      <ul class="intro-benefits">
        <li>Préparer votre voyage sereinement</li>
        <li>Éviter les oublis</li>
        <li>Faciliter l'organisation de votre séjour</li>
      </ul>
    </div>

    <!-- PROGRESS -->
    <div class="progress-wrap">
      <span class="progress-label">Ma check-list</span>
      <div class="progress-bar-bg"><div class="progress-bar-fill" id="progressFill"></div></div>
      <span class="progress-count" id="progressCount">0 / 9</span>
    </div>

    <!-- SECTION 1 -->
    <div class="section">
      <div class="section-header" onclick="toggleSection(this)">
        <div class="section-number">1</div>
        <div class="section-title">Les informations à nous transmettre après votre réservation</div>
        <div class="section-toggle open">▲</div>
      </div>
      <div class="section-body open">
        <div class="alert alert-info">
          <span class="alert-icon">📩</span>
          <div>Envoyez ces informations à notre équipe conciergerie : <a href="mailto:concierge@filovent.com" style="color:var(--blue-1);font-weight:600;">concierge@filovent.com</a> — dès que votre réservation est confirmée.</div>
        </div>
        <div class="alert alert-warning">
          <span class="alert-icon">⚠️</span>
          <div>Certaines informations peuvent ne pas s'appliquer à votre voyage.</div>
        </div>

        <div class="subsection-title">Ce que nous vous demandons</div>
        <ul class="bullet-list">
          <li>La copie du passeport de chaque passager (page avec photographie)</li>
          <li>Les informations de vols, si Filovent ne les a pas réservés :
            <ul class="bullet-list sub" style="margin-top:6px;">
              <li>Numéro de vol</li>
              <li>Aéroports de départ et d'arrivée</li>
              <li>Horaires aller et retour</li>
            </ul>
          </li>
          <li>Allergies alimentaires ou régimes spécifiques — à nous signaler <strong>au moins 2 semaines avant le départ</strong></li>
          <li>Besoins spécifiques : mobilité réduite, besoins médicaux</li>
        </ul>

        <div class="sep"></div>
        <p style="font-size:13.5px;color:var(--gray-8);line-height:1.6;">Ces informations nous permettent d'organiser votre accueil, vos transferts et votre embarquement. Sans elles, certaines prestations peuvent être difficiles à mettre en place.</p>
      </div>
    </div>

    <!-- SECTION 2 -->
    <div class="section">
      <div class="section-header" onclick="toggleSection(this)">
        <div class="section-number">2</div>
        <div class="section-title">Les éléments à vérifier avant votre départ</div>
        <div class="section-toggle open">▲</div>
      </div>
      <div class="section-body open">

        <div class="subsection">
          <div class="subsection-title">Documents de voyage</div>
          <div class="block-row">
            <div class="block-row-label">Passeport</div>
            <ul class="bullet-list" style="margin-top:6px;">
              <li>Valide au moins 6 mois après la date de retour (selon destination)</li>
              <li>Au moins 2 pages vierges</li>
              <li>Nom identique à celui des billets d'avion</li>
            </ul>
          </div>
          <div class="block-row">
            <div class="block-row-label">Visas</div>
            <ul class="bullet-list" style="margin-top:6px;">
              <li>Ils dépendent de votre nationalité et de votre destination</li>
              <li>C'est à vous de les effectuer</li>
              <li>Vérifiez-les auprès des autorités officielles</li>
            </ul>
          </div>
          <div class="alert alert-warning" style="margin-top:12px;margin-bottom:0;">
            <span class="alert-icon">⚠️</span>
            <div>Certaines démarches prennent plusieurs semaines. Anticipez.</div>
          </div>
        </div>

        <div class="sep"></div>

        <div class="subsection">
          <div class="subsection-title">Vols et transferts</div>
          <div class="block-row">
            <div class="block-row-label">Coordination des vols</div>
            <div class="block-row-text">Si Filovent n'a pas réservé vos vols, transmettez-nous vos informations de vol. Nous organiserons vos transferts.</div>
          </div>
          <div class="block-row">
            <div class="block-row-label">Enregistrement</div>
            <div class="block-row-text">Faites-le en ligne sur le site de votre compagnie aérienne. Cette étape n'est pas nécessaire pour les vols charter.</div>
          </div>
          <div class="block-row">
            <div class="block-row-label">Retard ou modification</div>
            <div class="block-row-text">Contactez-nous en cas de changement. Nous adapterons l'organisation.</div>
          </div>
          <div class="block-row">
            <div class="block-row-label">Transferts inclus</div>
            <div class="block-row-text">Retrouvez-les dans votre espace client, rubrique <strong>"Mes croisières"</strong>. Les horaires peuvent être confirmés avant le départ par nos partenaires locaux via WhatsApp.</div>
          </div>
        </div>

        <div class="sep"></div>

        <div class="subsection">
          <div class="subsection-title">Assurance voyage</div>
          <p style="font-size:14px;color:var(--navy);line-height:1.6;">Nous la recommandons vivement. Souscrivez-la via Filovent ou auprès de l'assureur de votre choix.</p>
        </div>

      </div>
    </div>

    <!-- SECTION 3 -->
    <div class="section">
      <div class="section-header" onclick="toggleSection(this)">
        <div class="section-number">3</div>
        <div class="section-title">Préparer vos effets personnels et votre budget</div>
        <div class="section-toggle">▲</div>
      </div>
      <div class="section-body">

        <div class="subsection">
          <div class="subsection-title">Bagages</div>
          <p style="font-size:14px;color:var(--gray-8);margin-bottom:10px;">Pensez à emporter :</p>
          <ul class="bullet-list">
            <li>Des vêtements adaptés au climat</li>
            <li>Des chaussures confortables</li>
            <li>Un adaptateur électrique si besoin</li>
          </ul>
        </div>

        <div class="sep"></div>

        <div class="subsection">
          <div class="subsection-title">Médicaments</div>
          <ul class="bullet-list">
            <li>Prévoyez une quantité suffisante pour tout le séjour</li>
            <li>Une ordonnance est recommandée</li>
            <li>Une trousse de premiers soins est conseillée</li>
            <li>Signalez tout besoin médical avant le départ</li>
          </ul>
        </div>

        <div class="sep"></div>

        <div class="subsection" style="margin-bottom:0;">
          <div class="subsection-title">Argent et paiements</div>
          <p style="font-size:14px;color:var(--navy);line-height:1.6;">Renseignez-vous sur la monnaie locale. Prévoyez des espèces pour les dépenses courantes.</p>
        </div>

      </div>
    </div>

    <!-- SECTION 4 — CHECKLIST -->
    <div class="section">
      <div class="section-header" onclick="toggleSection(this)">
        <div class="section-number">4</div>
        <div class="section-title">Vérification finale avant départ</div>
        <div class="section-toggle open">▲</div>
      </div>
      <div class="section-body open">
        <p style="font-size:13.5px;color:var(--gray-8);margin-bottom:16px;">Cliquez sur chaque point pour le valider.</p>
        <ul class="checklist" id="checklist">
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Passeport valide</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Copies des passeports envoyées</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Informations de vol transmises (si nécessaire)</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Enregistrement des vols effectué (hors charter)</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Régimes alimentaires signalés</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Assurance souscrite</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Médicaments préparés</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Documents de voyage accessibles</span></li>
          <li onclick="toggleCheck(this)"><div class="checklist-box"></div><span class="checklist-label">Contacts utiles enregistrés</span></li>
        </ul>
      </div>
    </div>

    <!-- HELP BOX -->
    <div class="help-box">
      <div class="help-box-icon">📩</div>
      <div class="help-box-text">
        <div class="help-box-title">Besoin d'aide ?</div>
        <div class="help-box-sub">Notre équipe est disponible pour vous accompagner à chaque étape.</div>
      </div>
      <a href="mailto:concierge@filovent.com" class="help-box-link">concierge@filovent.com</a>
    </div>

  </main>
</div>

<script>
  // Toggle sections
  function toggleSection(header) {
    const toggle = header.querySelector('.section-toggle');
    const body = header.nextElementSibling;
    const isOpen = body.classList.contains('open');
    body.classList.toggle('open', !isOpen);
    toggle.classList.toggle('open', !isOpen);
  }

  // Checklist + progress
  function toggleCheck(li) {
    li.classList.toggle('checked');
    updateProgress();
  }

  function updateProgress() {
    const items = document.querySelectorAll('#checklist li');
    const checked = document.querySelectorAll('#checklist li.checked').length;
    const total = items.length;
    const pct = Math.round((checked / total) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressCount').textContent = checked + ' / ' + total;
  }

  updateProgress();
</script>
</body>
</html>
